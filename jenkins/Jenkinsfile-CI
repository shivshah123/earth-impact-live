pipeline {
    agent any

    environment {
        ARTIFACT_NAME = "earth-impact-live.zip"
        SONAR_PROJECT_KEY = "earth-impact-live"
        SONAR_PROJECT_NAME = "Earth Impact Live"
    }

    stages {
        stage('Clone Source Code') {
            steps {
                git branch: 'main', url: 'https://github.com/shivshah123/earth-impact-live.git'
            }
        }

        stage('Install Dependencies') {
            steps {
                bat 'npm install'
            }
        }

        stage('SonarQube Code Quality Scan') {
    steps {
        script {
            def scannerHome = tool 'SonarScanner'
            withSonarQubeEnv('SonarQube-Server') {
                bat """
                "${scannerHome}\\bin\\sonar-scanner.bat" ^
                  -Dsonar.projectKey=%SONAR_PROJECT_KEY% ^
                  -Dsonar.projectName="%SONAR_PROJECT_NAME%" ^
                  -Dsonar.sources=. ^
                  -Dsonar.exclusions=node_modules/**,terraform/**,coverage/**,*.zip
                """
            }
        }
    }
}

        stage('Trivy Security Scan') {
    steps {
        bat '''
        "C:\\Users\\vishv\\AppData\\Local\\Microsoft\\WinGet\\Packages\\AquaSecurity.Trivy_Microsoft.Winget.Source_8wekyb3d8bbwe\\trivy.exe" fs . ^
          --severity HIGH,CRITICAL ^
          --ignore-unfixed ^
          --exit-code 0
        '''
    }
}

        stage('Build Application') {
            steps {
                bat 'npm run build'
            }
        }

        stage('Run Tests') {
            steps {
                bat 'npm test'
            }
        }

       stage('Package Application') {
    steps {
        bat '''
        if exist earth-impact-live.zip del earth-impact-live.zip

        tar.exe -a -c -f earth-impact-live.zip ^
        server.js ^
        package.json ^
        package-lock.json ^
        public ^
        routes ^
        controllers ^
        services ^
        models ^
        config
        '''
    }
}
        stage('Publish Artifact') {
            steps {
                archiveArtifacts artifacts: "${ARTIFACT_NAME}", fingerprint: true
            }
        }
    }
}